[colors]
;background = ${xrdb:color0:#222}
background = #262626
background-alt = #404040
;foreground = ${xrdb:color7:#222}
foreground = #F8F8F8
foreground-alt = #262626
primary = #E1AA5D
secondary = #7DC1CF
alert = #E84F4F

[padding]
inside-widget-padding = 1

[bar/example]
width = 100%
height = 25
;offset-x = 1%
;offset-y = 1%
;radius = 6.0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2
line-color = #fff

;border-size = 4
;border-color = #00000000
padding-left = 0
padding-right = 0

module-margin-left = 0
module-margin-right = 1

font-0 = Comfortaa:bold:pixelsize=12;2
font-1 = Comfortaa:pixelsize=13:bold;3
font-2 = feather:pixelsize=12;1

modules-left = i3 xwindow
modules-center = time
modules-right = updates ram cpu wlan pulseaudio xbacklight battery xkeyboard
tray-position = right
tray-padding = ${padding.inside-widget-padding}
tray-background = ${colors.background-alt}
;tray-background = #0063ff

;wm-restack = bspwm                                        
wm-restack = i3

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[module/xwindow]
type = internal/xwindow
label = " %title:0:30:...%"

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock
blacklist-1 = scroll lock

format = <label-layout><label-indicator>
format-underline = ${colors.primary}

label-layout = %name%
label-layout-underline = 
label-indicator-on-capslock = +CL
label-indicator-off-capslock = 
format-label-underline = 


label-indicator-padding = 2
label-indicator-margin = 0
label-indicator-background = ${colors.secondary}
format-indicator-underline = 
format-padding = ${padding.inside-widget-padding}
format-background = ${colors.background-alt}

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true

ws-icon-0 = term;Óßé
ws-icon-1 = qute;Ó•ł
ws-icon-2 = edit;Ó•®
ws-icon-3 = social;Óßć
ws-icon-4 = game;Ó•Ļ
ws-icon-5 = gimp;Ó¶Ā
ws-icon-6 = media;Ó®ē
ws-icon-7 = misc;Ó§∑
fuzzy-match = true
strip-wsnumbers = true

label-mode = %mode%
label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.primary}

; focused = Active workspace on focused monitor
label-focused = %icon% %name%
label-focused-background = ${colors.background-alt}
; label-focused-underline= ${colors.primary}
label-focused-padding = 2

; unfocused = Inactive workspace on any monitor
label-unfocused = %icon% %name%
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = %%icon% %name%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = %icon% %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

; Separator in between workspaces
; label-separator = |

[module/xbacklight]
type = internal/xbacklight

format = <label>
format-font = $(font2)
format-padding = ${padding.inside-widget-padding}
format-background = ${colors.background-alt}
label = Óß£ %percentage%%
format-foreground = ${colors.primary}
format-underline = ${colors.primary}

[module/cpu]
type = internal/cpu

interval = 2
format-prefix = ""
format-prefix-foreground = ${colors.secondary}
format-underline = ${colors.secondary}
label = %{A1:terminal -t "bpytop #widget" -e bpytop -b "cpu proc":}CPU: %percentage%%%{A}
format-padding = ${padding.inside-widget-padding}
format-background = ${colors.background-alt}

[module/ram]
type = custom/script
interval = 1

format = <label>
format-underline = ${colors.secondary}

exec = free -m | awk '$1 == "Mem:" {printf "%s\n", $3}'
label = RAM: %output% MB used
format-padding = ${padding.inside-widget-padding}
format-background = ${colors.background-alt}
click-left = terminal -t "bpytop #widget" -e bpytop -b "mem proc"

[module/wlan]
type = internal/network
interface = ${env:ETH:wlan0}
interval = 3.0

format-connected = <label-connected>
format-connected-underline = #9B64FB
label-connected = %{A1:networkmanager-dmenu:}%essid%%{A}
format-disconnected = ""
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}
unknown-as-up = true
ramp-signal-foreground = ${colors.foreground-alt}
format-connected-padding = ${padding.inside-widget-padding}
format-connected-background = ${colors.background-alt}

[module/time]
type = custom/script
interval = 1

format = <label>
;format-underline = ${colors.primary}

exec= date "+%H:%M %d.%m.%y"
label = %output%
label-font = 2
format-padding = 3
;${padding.inside-widget-padding}
;format-background = ${colors.background-alt}
click-left = terminal -t "terminal #widget date" -e zsh -c "cal -ywm --color; read"

[module/pulseaudio]
type = internal/pulseaudio

format-volume = Ó®č <label-volume>
label-volume = "%percentage%%"
format-volume-font = $(font2)
format-volume-foreground = ${colors.primary}
format-volume-underline = ${colors.primary}

label-muted = muted
label-muted-foreground = ${colors.alert}
format-muted-underline = ${colors.primary}
format-muted-padding = ${padding.inside-widget-padding}

click-right = terminal -t 'pulsemixer #mini #widget' -e 'pulsemixer'

format-volume-padding = ${padding.inside-widget-padding}
format-volume-background = ${colors.background-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-charging = %{A1:/home/obey/.config/rofi/applets/applets/powermenu.sh:}ÓßÄ <label-charging>%{A}
format-charging-underline = ${colors.primary}
format-charging-prefix-foreground = ${colors.primary}
format-charging-prefix-font  = $(font2)
format-charging-foreground = ${colors.primary}
format-charging-padding = ${padding.inside-widget-padding}
format-charging-background = ${colors.background-alt}

format-discharging = %{A1:/home/obey/.config/rofi/applets/applets/powermenu.sh:}ÓßÄ <label-discharging>%{A}
format-discharging-underline = ${self.format-charging-underline}
format-discharging-prefix-foreground = ${colors.primary}
format-discharging-prefix-font  = $(font2)
format-discharging-foreground = ${colors.primary}
format-discharging-padding = ${padding.inside-widget-padding}
format-discharging-background = ${colors.background-alt}

format-full-prefix = %{A1:/home/obey/.config/rofi/applets/applets/powermenu.sh:}ÓßÄ %{A}
format-full-prefix-foreground = ${colors.primary}
format-full-foreground = ${colors.primary}
format-full-prefix-font  = $(font2)
format-full-underline = ${self.format-charging-underline}
format-full-padding = ${padding.inside-widget-padding}
format-full-background = ${colors.background-alt}

click-left = A1:/home/obey/.config/rofi/applets/applets/powermenu.sh

[global/wm]
margin-top = 0
margin-bottom = 0

[settings]
screenchange-reload = true

[module/updates]
type = custom/script

exec = "checkupdates | wc -l"
interval = 60
format = <label>
label = %{A1:terminal -t 'checkupdates #mini #widget' -e zsh -is eval 'yay -Suy && sleep 3 && exit':}UPD: %output:0:10:...%%{A}
format-padding = ${padding.inside-widget-padding}
format-background = ${colors.background-alt}
format-underline = ${colors.secondary}

; vim:ft=dosini
